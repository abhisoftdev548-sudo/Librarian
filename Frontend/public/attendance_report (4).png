                    </tr>
                  
                    <tr>
                      <td><strong>4</strong></td>
                      <td>Hukum Singh</td>
                      <td>CS</td>
                      <td>2nd</td>
                    </tr>
                  
                    <tr>
                      <td><strong>5</strong></td>
                      <td>Ketan prajapati</td>
                      <td>CS</td>
                      <td>2nd</td>
                    </tr>
                  
                    <tr>
                      <td><strong>6</strong></td>
                      <td>Prabal Dixit</td>
                      <td>EE</td>
                      <td>2nd</td>
                    </tr>
                  
                    <tr>
                      <td><strong>7</strong></td>
                      <td>Raghvendra Ahirvar</td>
                      <td>EE</td>
                      <td>2nd</td>
                    </tr>
                  
                    <tr>
                      <td><strong>8</strong></td>
                      <td>Rajraja Bundela</td>
                      <td>CS</td>
                      <td>2nd</td>
                    </tr>
                  
                    <tr>
                      <td><strong>9</strong></td>
                      <td>Shiv Agraval</td>
                      <td>IT</td>
                      <td>2nd</td>
                    </tr>
                  
                    <tr>
                      <td><strong>10</strong></td>
                      <td>Shivansh Yadav</td>
                      <td>CS</td>
                      <td>2nd</td>
                    </tr>
                  
                </tbody>
              </table>
            </div>

            <div class="footer">
              <p>✓ Generated by Attendance Taker Application</p>
              <p><strong>Created by:</strong> Abhishek</p>
            </div>
          </div>
        </body>
      </html>
    