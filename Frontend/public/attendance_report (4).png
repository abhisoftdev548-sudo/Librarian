                </div>
              
                <div class="stat-card">
                  <div class="stat-number">2</div>
                  <div class="stat-label">IT</div>
                </div>
              
            </div>

            <div class="table-section">
              <div class="section-title">👥 Present Students Details</div>
              <table>
                <thead>
                  <tr>
                    <th style="width: 5%;">S.No</th>
                    <th style="width: 40%;">Name</th>
                    <th style="width: 30%;">Branch</th>
                    <th style="width: 25%;">Semester</th>
                  </tr>
                </thead>
                <tbody>
                  
                    <tr>
                      <td><strong>1</strong></td>
